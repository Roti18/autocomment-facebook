# Facebook Auto Commenter — Beranda Scroll Mode

# Headless mode: false = liat browser (untuk login pertama), true = jalan di background
HEADLESS=false

# Directory session browser (cookies, localStorage)
FB_USER_DATA_DIR=./user_data

# ─────────────────────────────────────
# BERANDA SCROLL SETTINGS
# ─────────────────────────────────────
# Berapa kali scroll di beranda. 40-60 scroll cukup untuk dapet banyak post.
# Delay bakal di-random 0.8x-1.5x dari nilai ini biar makin natural.
BERANDA_SCROLL_COUNT=50
BERANDA_SCROLL_DELAY=5

# ─────────────────────────────────────
# KEYWORD FILTER
# ─────────────────────────────────────
# Post harus mengandung salah satu keyword ini baru di-comment.
# Pisah pake koma. Kosongin = comment SEMUA post (tidak disarankan).
TARGET_KEYWORDS=parfum,mykonos,velixir,wangi,minyak

# ─────────────────────────────────────
# READING SIMULATION
# ─────────────────────────────────────
# Delay (detik) sebelum comment — simulasi baca postingan dulu.
# Minimal 15-30 detik biar natural.
READING_DELAY_MIN=20
READING_DELAY_MAX=45

# ─────────────────────────────────────
# COOLDOWN AFTER COMMENT
# ─────────────────────────────────────
# Jeda antar komentar (detik). Makin tinggi makin aman dari FB spam detection.
# Recommended: 90-300 detik (1.5 - 5 menit)
COOLDOWN_MIN=120
COOLDOWN_MAX=300

# ─────────────────────────────────────
# LONG BREAK
# ─────────────────────────────────────
# Setelah N komentar, istirahat panjang biar ga kelihatan bot.
LONG_BREAK_INTERVAL=4
LONG_BREAK_MINUTES=15

# ─────────────────────────────────────
# MAX COMMENT PER RUN
# ─────────────────────────────────────
# Maksimal komentar dalam satu sesi jalan.
# Recommended: 15-25 untuk akun baru, 30-50 untuk akun mature.
MAX_TOTAL_COMMENTS=25

# ─────────────────────────────────────
# COMMENT TEMPLATE
# ─────────────────────────────────────
COMMENT_TEMPLATE_PATH=comment_template.txt

# (Optional) Path ke image untuk attach di komentar
COMMENT_IMAGE_PATH=

# ─────────────────────────────────────
# PROFILE
# ─────────────────────────────────────
# Profile URL sendiri — biarin kosong biar auto-detect.
MY_PROFILE_URL=
