# Facebook Auto Commenter Configuration

# Headless mode: set to false to see the browser GUI and log in manually on first run.
# Set to true only when the session is saved and you want to run completely in the background.
HEADLESS=false

# Directory to store user session, cookies, and localStorage.
# Relative to root directory or absolute path.
FB_USER_DATA_DIR=./user_data

# Delay constraints (in seconds) between comments to avoid FB spam detection.
# Recommended: min 45, max 90 for safe operation.
MIN_DELAY_SECONDS=45
MAX_DELAY_SECONDS=90

# Interval limit (in minutes) to prevent commenting in the same group too quickly.
POST_INTERVAL_MINUTES=120

# Optional: Your own profile URL (e.g. https://www.facebook.com/username)
# Leaving this blank will cause the bot to automatically detect your profile URL during bootstrap.
MY_PROFILE_URL=

# Comma-separated list of keywords that target posts must contain.
# Leave empty to comment on ALL posts with no filter.
TARGET_KEYWORDS=

# Maximum number of posts to comment on per group in a single run.
# Recommended: 3-5 for safe operation.
MAX_COMMENTS_PER_GROUP=5

# Scraper feed scrolling configuration.
# SCROLL_COUNT: Number of times the bot scrolls down the feed per group.
SCROLL_COUNT=8

# SCROLL_DELAY_SECONDS: Time (in seconds) to wait for new posts to load after each scroll.
SCROLL_DELAY_SECONDS=3

# Path to the comment template file (supports Spintax {option1|option2} format).
COMMENT_TEMPLATE_PATH=comment_template.txt

# (Optional) Path to an image file to attach to every comment.
# Accepts absolute or relative path (e.g. ./assets/promo.jpg).
# Leave blank for text-only comments.
COMMENT_IMAGE_PATH=
