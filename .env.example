# Facebook Auto Commenter Configuration

# Headless mode: set to false to see the browser GUI and log in manually on first run.
# Set to true only when the session is saved and you want to run completely in the background.
HEADLESS=false

# Directory to store user session, cookies, and localStorage.
# Relative to root directory or absolute path.
FB_USER_DATA_DIR=./user_data

# Delay constraints (in seconds) between comments in multiple groups to avoid FB spam detection.
MIN_DELAY_SECONDS=60
MAX_DELAY_SECONDS=180

# Interval limit (in minutes) to prevent commenting in the same group too quickly.
POST_INTERVAL_MINUTES=60

# Optional: Your own profile URL (e.g. https://www.facebook.com/username)
# Leaving this blank will cause the bot to automatically detect your profile URL during bootstrap.
MY_PROFILE_URL=

# Comma-separated list of keywords that target posts must contain.
TARGET_KEYWORDS=harga,ready,jual,parfum,rekomen,mykonos

# Maximum age of posts to comment on (in days).
MAX_POST_AGE_DAYS=5

# Maximum number of posts to comment on per group in a single run.
MAX_COMMENTS_PER_GROUP=3

# Path to the comment template file containing Spintax formatting
COMMENT_TEMPLATE_PATH=comment_template.txt
